# 各プロジェクトは個別の .gitignore を持つ
# ここはルートレベルの除外設定

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
*.swp
*.swo

# Python
__pycache__/
*.pyc

# ローカル専用のClaude Code設定（マシン固有の絶対パス・許可設定を含むためコミットしない）
.claude/

# Secrets（念のため）
*.env
.env
config.json
99_System_Logs/google_credentials.json
99_System_Logs/google_token.json
